[Unit]
Description=Dataslate FastAPI backend
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/dataslate/backend
EnvironmentFile=/home/ubuntu/dataslate/.env
ExecStart=/home/ubuntu/dataslate/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
